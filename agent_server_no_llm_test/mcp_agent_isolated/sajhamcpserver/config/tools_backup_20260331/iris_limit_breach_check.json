{
  "name": "iris_limit_breach_check",
  "implementation": "sajha.tools.impl.iris_ccr_tools.IrisLimitBreachCheckTool",
  "description": "Check whether a specific counterparty is breaching any limits on a given date, across product, customer, or connection level. Returns breach list with limit_key, overage amount, and overage percentage.",
  "version": "1.0.0",
  "enabled": true,
  "data_path": "${data.iris_combined_csv}",
  "inputSchema": {
    "type": "object",
    "properties": {
      "date": {"type": "string", "description": "Snapshot date YYYY-MM-DD. Defaults to latest."},
      "counterparty_code": {"type": "string", "description": "Customer Code (exact match)"},
      "legal_entity": {"type": "string", "enum": ["BCMC","HARRIS BANK","BMO","BNBI","BOMI","BHIC","BMN","BCML","BLAC","BMMC"]},
      "product": {"type": "string", "description": "Product partial match"},
      "level": {"type": "string", "enum": ["product","customer","connection"], "description": "Limit level to check. Default: all levels."}
    },
    "required": ["counterparty_code"]
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "category": "Risk Data",
    "tags": ["iris", "ccr", "counterparty credit risk", "limits", "exposure"],
    "rateLimit": 60,
    "cacheTTL": 300,
    "copyright": "Copyright All Rights Reserved 2025-2030"
  }
}
