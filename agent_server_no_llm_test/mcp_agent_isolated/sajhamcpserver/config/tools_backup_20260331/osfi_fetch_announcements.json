{
  "name": "osfi_fetch_announcements",
  "implementation": "sajha.tools.impl.osfi_tools.OsfiFetchAnnouncementsTool",
  "description": "Fetch latest content from live OSFI announcement and guidance pages using Tavily. Filter by category: news, quarterly_release, guideline, schedule, risk_outlook, dsb. Use for latest OSFI news, quarterly releases, upcoming guidance.",
  "version": "1.0.0",
  "enabled": true,
  "cacheTTL": 0,
  "inputSchema": {
    "type": "object",
    "properties": {
      "category": {
        "type": "string",
        "enum": ["news", "quarterly_release", "guideline", "schedule", "risk_outlook", "dsb", "all"],
        "description": "Filter URLs by category. Default: news."
      },
      "max_items": {"type": "integer", "description": "Max URLs to fetch. Default: all in category."}
    },
    "required": []
  },
  "urls": [
    {"name": "News & Announcements", "url": "https://www.osfi-bsif.gc.ca/en/news", "category": "news", "description": "OSFI main news and announcements page"},
    {"name": "Quarterly Release Q1 2026", "url": "https://www.osfi-bsif.gc.ca/en/news/osfis-quarterly-release-continuing-advance-smart-well-calibrated-risk-taking", "category": "quarterly_release", "description": "Q1 2026 quarterly release"},
    {"name": "Policy Releases Schedule", "url": "https://www.osfi-bsif.gc.ca/en/about-osfi/progress-our-initiatives/modernizing-policies-guidance-supervision-regulatory-efficiency/osfis-policy-releases-announcements-schedule", "category": "schedule", "description": "Quarterly release dates and upcoming guidance schedule"},
    {"name": "Modernizing Policies", "url": "https://www.osfi-bsif.gc.ca/en/about-osfi/progress-our-initiatives/modernizing-policies-guidance-supervision-regulatory-efficiency", "category": "modernization", "description": "Modernizing policies and regulatory efficiency"},
    {"name": "Guidance Library", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library", "category": "guidance_library", "description": "Full OSFI guidance library"},
    {"name": "Annual Risk Outlook", "url": "https://www.osfi-bsif.gc.ca/en/supervision/annual-risk-outlook", "category": "risk_outlook", "description": "Annual risk outlook"},
    {"name": "CAR Guideline 2026", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/capital-adequacy-requirements-guideline-2026", "category": "guideline", "description": "Capital Adequacy Requirements 2026"},
    {"name": "LAR Guideline 2026", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/liquidity-adequacy-requirements-lar-guideline-2026", "category": "guideline", "description": "Liquidity Adequacy Requirements 2026"},
    {"name": "E-23 Model Risk 2027", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/guideline-e-23-model-risk-management-2027", "category": "guideline", "description": "E-23 Model Risk Management 2027"},
    {"name": "B-10 Third Party Risk", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/b-10-third-party-risk-management", "category": "guideline", "description": "B-10 Third-Party Risk Management"},
    {"name": "B-13 Technology & Cyber", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/b-13-technology-cyber-risk-management", "category": "guideline", "description": "B-13 Technology and Cyber Risk"},
    {"name": "B-20 Residential Mortgage", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/b-20-residential-mortgage-underwriting-practices-procedures", "category": "guideline", "description": "B-20 Residential Mortgage Underwriting"},
    {"name": "B-15 Climate Risk", "url": "https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/b-15-climate-risk-management", "category": "guideline", "description": "B-15 Climate Risk Management"},
    {"name": "Domestic Stability Buffer", "url": "https://www.osfi-bsif.gc.ca/en/supervision/domestic-stability-buffer", "category": "dsb", "description": "Domestic Stability Buffer announcements"}
  ],
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "category": "Regulatory Intelligence",
    "tags": ["osfi", "bsif", "regulatory", "announcements", "news"],
    "rateLimit": 30,
    "cacheTTL": 0,
    "copyright": "Copyright All Rights Reserved 2025-2030"
  }
}
