{
  "name": "iris_rating_screen",
  "implementation": "sajha.tools.impl.iris_ccr_tools.IrisRatingScreenTool",
  "description": "Portfolio-wide screen — filter and rank counterparties by internal rating band, country rating, or minimum exposure. No counterparty_code needed — screens all counterparties.",
  "version": "1.0.0",
  "enabled": true,
  "data_path": "${data.iris_combined_csv}",
  "inputSchema": {
    "type": "object",
    "properties": {
      "date": {"type": "string", "description": "Snapshot date YYYY-MM-DD. Defaults to latest."},
      "min_rating": {"type": "integer", "description": "Minimum internal rating (1-10)"},
      "max_rating": {"type": "integer", "description": "Maximum internal rating (1-10)"},
      "country_rating": {"type": "string", "description": "S&P-style country rating e.g. AAA, AA, BBB"},
      "legal_entity": {"type": "string", "enum": ["BCMC","HARRIS BANK","BMO","BNBI","BOMI","BHIC","BMN","BCML","BLAC","BMMC"]},
      "country": {"type": "string"},
      "min_exposure": {"type": "number", "description": "Minimum product exposure"}
    },
    "required": []
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "category": "Risk Data",
    "tags": ["iris", "ccr", "counterparty credit risk", "limits", "exposure"],
    "rateLimit": 60,
    "cacheTTL": 300,
    "copyright": "Copyright All Rights Reserved 2025-2030"
  }
}
