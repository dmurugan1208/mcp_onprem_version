# ══════════════════════════════════════════════════════════════════════════════
# Agent Server - No LLM Configuration
# This config starts the agent server WITHOUT any LLM provider
# REST API endpoints will work, but agent execution endpoints will not
# ══════════════════════════════════════════════════════════════════════════════

# ──────────── LLM Provider (DISABLED) ────────────────────────────────────────
# NOT SETTING: ANTHROPIC_API_KEY (Optional - server starts without it)
# NOT SETTING: ANTHROPIC_MODEL (Optional - uses fallback if not set)
# NOT SETTING: XAI_API_KEY
# NOT SETTING: HF_API_KEY
# NOT SETTING: GROQ_API_KEY
# NOT SETTING: LLM_PROVIDER

# ──────────── Agent / LangGraph ────────────────────────────────────────────────
# Context management thresholds (tokens)
CONTEXT_WARN_TOKENS=120000
CONTEXT_HARD_TOKENS=160000
CONTEXT_MAX_TOKENS=128000
CONTEXT_TRIGGER_TOKENS=5200
CONTEXT_TARGET_PCT=0.009375
CONTEXT_MIN_EXCHANGES_BETWEEN_SUMMARIES=1
CONTEXT_TAIL_MESSAGES=2

# ──────────── Auth ────────────────────────────────────────────────────────────
# Comma-separated API keys for agent server (leave blank to disable in local dev)
AGENT_API_KEYS=

# JWT signing secret — set a long random string in production
JWT_SECRET=test-secret-no-llm

# ──────────── Internal Service URLs ───────────────────────────────────────────
# SAJHA server URL (not required for API-only mode)
SAJHA_BASE_URL=http://127.0.0.1:3002
# API key for agent→SAJHA service calls (from sajhamcpserver/config/apikeys.json)
SAJHA_API_KEY=sja_full_access_admin

# ──────────── Storage ─────────────────────────────────────────────────────────
STORAGE_BACKEND=local

# ══════════════════════════════════════════════════════════════════════════════
# All LLM providers are OPTIONAL - remove the # to enable:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ══════════════════════════════════════════════════════════════════════════════
