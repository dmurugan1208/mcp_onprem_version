# ─── LLM Provider ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# Set to 'bedrock' for AWS Bedrock; requires langchain-aws and boto3
LLM_PROVIDER=anthropic

# ─── Agent / LangGraph ───────────────────────────────────────────────────────
# Context management thresholds (tokens)
CONTEXT_WARN_TOKENS=120000
CONTEXT_HARD_TOKENS=160000

# ─── Auth ────────────────────────────────────────────────────────────────────
# Comma-separated API keys for agent server (leave blank to disable in local dev)
AGENT_API_KEYS=

# JWT signing secret — set a long random string in production
JWT_SECRET=change-me-in-production

# ─── Internal Service URLs ───────────────────────────────────────────────────
# In Docker these are internal loopback addresses managed by supervisord.
# Override only if running processes separately.
SAJHA_BASE_URL=http://127.0.0.1:3002
# API key for agent→SAJHA service calls (from sajhamcpserver/config/apikeys.json)
SAJHA_API_KEY=sja_full_access_admin

# JWT signing secret — set a long random string in production
JWT_SECRET=change-me-in-production

# Comma-separated allowed CORS origins (add your frontend domain in production)
# CORS_ORIGINS=https://yourdomain.com

# ─── External APIs ───────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-REPLACE_ME
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__REPLACE_ME
# LANGCHAIN_PROJECT=riskgpt-platform

# ─── Storage ─────────────────────────────────────────────────────────────────
# Current backend: local filesystem (paths defined in sajhamcpserver/config/application.properties)
# Future: set STORAGE_BACKEND=s3 when migrating to object storage
STORAGE_BACKEND=local

# S3 settings (reserved — do not implement until STORAGE_BACKEND=s3)
# S3_BUCKET=riskgpt-data
# S3_PREFIX=platform/
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=REPLACE_ME
# AWS_SECRET_ACCESS_KEY=REPLACE_ME

# ─── Bedrock (enterprise, optional) ─────────────────────────────────────────
# Uncomment when LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-v1
